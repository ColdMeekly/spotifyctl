# Normalize text files to LF in the repo.
* text=auto eol=lf

# Windows-native project files — keep CRLF so MSBuild/VS stay happy.
*.sln           text eol=crlf
*.vcxproj       text eol=crlf
*.vcxproj.filters text eol=crlf
*.vcxproj.user  text eol=crlf
*.props         text eol=crlf

# Binary assets.
*.lib binary
*.dll binary
*.exe binary
*.pdb binary
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.whl binary
*.tgz binary
*.gz  binary
*.zip binary
